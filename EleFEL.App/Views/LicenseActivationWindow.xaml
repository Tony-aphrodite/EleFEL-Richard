<Window x:Class="EleFEL.App.Views.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EleFEL - Activación de Licencia"
        Width="520" Height="460"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        KeyDown="Window_KeyDown">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}"
                CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Activación de Licencia"
                           Foreground="White" FontSize="22" FontWeight="Bold" />
                <TextBlock Text="Ingrese la llave que recibió al adquirir EleFEL."
                           Foreground="#DBEAFE" FontSize="13" Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <!-- Key Input Label -->
        <TextBlock Grid.Row="1" Text="Llave de Licencia:" FontSize="13"
                   FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,6" />

        <!-- Key Input -->
        <TextBox Grid.Row="2" x:Name="txtLicenseKey"
                 Style="{StaticResource InputTextBox}"
                 FontSize="18" FontFamily="Consolas"
                 CharacterCasing="Upper"
                 MaxLength="64"
                 Margin="0,0,0,10" />

        <!-- Activate Button -->
        <Button Grid.Row="3" x:Name="btnActivate"
                Content="Activar (Enter)"
                Style="{StaticResource PrimaryButton}"
                FontSize="15" Padding="20,12"
                Margin="0,0,0,12"
                Click="BtnActivate_Click" />

        <!-- Status Message -->
        <Border Grid.Row="4" x:Name="pnlStatus"
                Background="#F1F5F9" CornerRadius="6" Padding="12"
                Visibility="Collapsed" Margin="0,0,0,10">
            <TextBlock x:Name="txtStatus" FontSize="13" TextWrapping="Wrap"
                       Foreground="{StaticResource TextBrush}" />
        </Border>

        <!-- Current state (if already activated) -->
        <Border Grid.Row="5" x:Name="pnlCurrent"
                Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1"
                CornerRadius="6" Padding="12"
                Visibility="Collapsed" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Licencia actual:" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock x:Name="txtCurrentName" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock x:Name="txtCurrentExpires" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Help Text -->
        <StackPanel Grid.Row="6" VerticalAlignment="Bottom" Margin="0,10,0,15">
            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Text="¿No tiene una llave? Contacte al proveedor por WhatsApp al +502 5017 8887 para adquirir su suscripción mensual." />
        </StackPanel>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="btnCancel"
                    Content="Cancelar (Esc)"
                    Style="{StaticResource PrimaryButton}"
                    Background="#6B7280"
                    Click="BtnCancel_Click" />
        </Grid>
    </Grid>
</Window>
